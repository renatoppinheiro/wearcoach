# Copy this file to .env and fill in what you have. Nothing here ever
# leaves your machine except direct calls to Strava/Oura/Garmin/your LLM.

# --- Pick ONE llm provider ---
LLM_PROVIDER=anthropic          # anthropic | openai
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Strava (required) ---
# Create your own app at https://www.strava.com/settings/api (2 minutes).
# Authorization Callback Domain: localhost
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# --- Oura (optional — only if you own a ring) ---
# Create your own app at https://cloud.ouraring.com/oauth/applications
# Redirect URI: http://localhost:8734/callback
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=

# --- Garmin (optional — password never leaves your machine, sent only ---
# --- to Garmin's own login endpoint via the garminconnect library) -----
GARMIN_EMAIL=
GARMIN_PASSWORD=
